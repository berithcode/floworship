{
  "name": "floworship",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@floworship/web",
    "dev:api": "turbo run dev --filter=@floworship/api",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@floworship/web",
    "build:api": "turbo run build --filter=@floworship/api",
    "lint": "turbo run lint",
    "preview": "npm run preview --workspace=@floworship/web",
    "test": "turbo run test",
    "db:migrate": "npm run db:migrate --workspace=@floworship/api",
    "db:generate": "npm run db:generate --workspace=@floworship/api",
    "db:seed": "npm run db:seed --workspace=@floworship/api"
  },
  "devDependencies": {
    "turbo": "^2.10.2"
  }
}